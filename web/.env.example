# Stratos Akademi — ortam değişkenleri örneği.
# Bu dosyayı `web/.env.local` olarak kopyalayıp gerçek değerleri doldur.
# .env.local gitignore'dadır; ASLA commit'lenmez.

# --- Supabase (zorunlu) ---
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# YALNIZ sunucu tarafı (server action'lar). Asla NEXT_PUBLIC_ değil, asla commit'lenmez.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- E-posta bildirimleri (opsiyonel — yoksa e-posta sessizce atlanır) ---
# Görev onay/red e-postalarındaki mutlak link için prod adresi.
NEXT_PUBLIC_SITE_URL=https://stratosiha.com
# https://resend.com -> API Keys
RESEND_API_KEY=<resend-key>
# Resend'de doğrulanmış gönderen.
MAIL_FROM=Stratos Akademi <bildirim@alanadi.com>

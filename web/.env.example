# Stratos Akademi — ortam değişkenleri örneği.
# Bu dosyayı `web/.env.local` olarak kopyalayıp gerçek değerleri doldur.
# .env.local gitignore'dadır; ASLA commit'lenmez.

# --- Supabase (zorunlu) ---
NEXT_PUBLIC_SUPABASE_URL=https://<proje-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
# YALNIZ sunucu tarafı (server action'lar). Asla NEXT_PUBLIC_ değil, asla commit'lenmez.
SUPABASE_SERVICE_ROLE_KEY=<service-role-key>

# --- E-posta bildirimleri (opsiyonel — yoksa e-posta sessizce atlanır) ---
# Görev onay/red e-postalarındaki mutlak link için prod adresi.
NEXT_PUBLIC_SITE_URL=https://stratosiha.com
# https://resend.com -> API Keys
RESEND_API_KEY=<resend-key>
# Resend'de doğrulanmış gönderen.
MAIL_FROM=Stratos Akademi <bildirim@alanadi.com>

# --- Otomatik video önerileri ---
# https://console.cloud.google.com -> YouTube Data API v3
YOUTUBE_API_KEY=<youtube-data-api-key>
# https://aistudio.google.com/apikey (Gemini ücretsiz katman)
GOOGLE_API_KEY=<gemini-api-key>
# Cron route'unu koruyan rastgele uzun dizge (GitHub secret ile aynı).
# YOKSA cron uç noktası HER isteği 401'ler → otomatik tarama hiç koşmaz.
CRON_SECRET=<rastgele-uzun-dizge>

# Gemini modeli (opsiyonel). Boş bırak: kod gemini-flash-lite-latest → gemini-flash-latest
# zincirini dener ve 404/429 alırsa sonrakine düşer. Sabit model adları eskiyor.
# GEMINI_MODEL=gemini-flash-lite-latest

# Aday filtresi eşikleri (opsiyonel). Küçük/niş müfredatta varsayılanlar çok sert kalabilir;
# admin panelindeki "Tarama Geçmişi" hangi eşiğin kaç videoyu elediğini gösterir.
# VIDEO_MIN_VIEWS=10000
# VIDEO_MIN_SURE_SN=180
# VIDEO_MAX_YAS_YIL=4

# --- Migration uygulamak için (opsiyonel, yalnız yerel) ---
# Supabase Dashboard → Settings → Database → Connection string → Session pooler (URI).
# `node scripts/migrate.mjs` bunu kullanır. ASLA commit'lenmez.
DATABASE_URL=postgresql://postgres.<ref>:<sifre>@aws-0-<bolge>.pooler.supabase.com:5432/postgres
